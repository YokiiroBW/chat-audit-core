# Application
APP_NAME=chat-audit-core
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=replace-with-a-long-random-secret
SYSTEM_INSTANCE_ID=chat-audit-core
ADMIN_API_TOKEN=replace-with-admin-api-token

# Database: production/deployment should use PostgreSQL
POSTGRES_DB=chat_audit
POSTGRES_USER=chat_audit
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Local quick test alternative:
# DATABASE_URL=sqlite+aiosqlite:///./data/chat_audit.sqlite3

# Storage
STORAGE_ROOT=./data/storage
BACKUP_ROOT=./data/backups
PUBLIC_STORAGE_PREFIX=/static/storage

# OneBot / NapCat reverse websocket
ONEBOT_WS_PATH=/onebot/v11/ws
ONEBOT_ACCESS_TOKEN=replace-with-onebot-access-token

# Media downloader
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=30
MEDIA_MAX_BYTES=104857600
FFMPEG_BIN=ffmpeg
MEDIA_TRANSCODE_ENABLED=false
MEDIA_TRANSCODE_VOICE_EXT=mp3
MEDIA_TRANSCODE_VIDEO_EXT=mp4
HIGH_RISK_RATE_LIMIT_PER_MINUTE=10

# Backup
AUTO_BACKUP_CRON=0 3 * * *
AUTO_BACKUP_KEEP_LATEST=7
